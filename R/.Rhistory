"Plant_Control_1,400,600,800,1200,1800,2400,2500,2500",
"Plant_Control_2,410,610,810,1250,1850,2450,2550,2550",
"Plant_Stress_1, 420,650,900,1500,1600,1700,1750,1750",
"Plant_Stress_2, 430,660,910,1550,1650,1750,1800,1800",
"End Of File"
)
writeLines(csv_content, "teste_handypea.csv")
cat(">>> 1. Arquivo de teste criado.\n")
# --- 2. TESTAR A LEITURA E CÁLCULO (Biolyzer Logic) ---
# Isso testa as funções read_handypea_csv, handypea_to_ojip e calc_fluorojip
tryCatch({
resultados <- calc_fluorojip_handypea("teste_handypea.csv")
# Vamos adicionar uma coluna de tratamento fictícia para os gráficos
resultados$treatment <- c("Control", "Control", "Stress", "Stress")

plot_normalized_fluorescence <- function(file) {
# 1. Ler dados usando a função que já consertamos
raw <- read_handypea_csv(file)
times <- raw$times_s
mat <- raw$mat
ids <- rownames(mat)
# 2. Configurar cores
cols <- rainbow(nrow(mat))
# 3. Plotar (Escala Logarítmica no eixo X é o padrão para OJIP)
# type = "n" cria o gráfico vazio primeiro
plot(times, mat[1, ], log = "x", type = "n",
ylim = range(mat, na.rm = TRUE),
xlab = "Tempo (s)", ylab = "Fluorescência (a.u.)",
main = "Cinética OJIP (HandyPEA)")
# 4. Adicionar linhas
for(i in seq_len(nrow(mat))) {
lines(times, mat[i, ], col = cols[i], lwd = 2)
}
legend("topleft", legend = ids, col = cols, lwd = 2, bty = "n", cex = 0.8)
grid()
}
plot_normalized_fluorescence("teste_final.csv")

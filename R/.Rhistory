#' Example OJIP Data
#'
#' A dataset containing example fluorescence values for JIP-test calculation.
#'
#' @format A data frame with multiple rows and columns (fo, fm, j, i, etc.)
#' @usage data(example_fluorojip)
"example_fluorojip"
write_normalized_jiptable
devtools::document()
devtools::check()
library(fluorojip)
# Carregar o dado que documentamos
data("example_fluorojip")
# Verificar se os dados carregaram corretamente
head(example_fluorojip)
res <- calc_fluorojip(example_fluorojip)
# Verificar se colunas como Fv_Fm e PI_abs foram criadas
print(res[1:5, c("sample_id", "Fv_Fm", "PI_abs", "ABS_RC")])
# Selecionar alguns parâmetros para o heatmap
meus_params <- c("Fv_Fm", "PI_abs", "ABS_RC", "DIo_RC", "area")
plot_heatmap_fluorojip(res,
params = meus_params,
group_col = "treatment",
scale = "zscore",
main = "Teste de Heatmap - fluorojip")
plot_3d_fluorojip(res,
params = c("Fv_Fm", "PI_abs", "area"),
group_col = "treatment")
library(fluorojip)
# 1. Carregar os dados (usando o exemplo do pacote ou o seu arquivo)
data("example_fluorojip")
# 2. Calcular todos os parâmetros JIP
# A função calc_fluorojip aplicará as fórmulas que revisamos em todas as linhas
resultados_completos <- calc_fluorojip(example_fluorojip)
# 3. Visualizar as primeiras linhas no console
print(head(resultados_completos))
# 4. Salvar o resultado em um arquivo CSV para o revisor ou para o Excel
# Isso vai criar um arquivo chamado "meus_resultados_ojip.csv" na sua pasta
write.csv(resultados_completos, "meus_resultados_ojip.csv", row.names = FALSE)
message("Cálculos concluídos e salvos em 'meus_resultados_ojip.csv'!")
devtools::document()
devtools::check()
library(fluorojip)
# 1. Carregar os dados de exemplo
data("example_fluorojip")
# 2. Gerar os novos cálculos com a proteção contra ruído
res <- calc_fluorojip(example_fluorojip)
# 3. Verificar se existem valores negativos nos parâmetros críticos
# Criamos uma tabela de conferência
check_negativos <- data.frame(
Minimo_PI_abs = min(res$PI_abs, na.rm = TRUE),
Minimo_phi_Eo = min(res$phi_Eo, na.rm = TRUE),
Minimo_psi_Eo = min(res$psi_Eo, na.rm = TRUE),
Minimo_ETo_RC = min(res$ETo_RC, na.rm = TRUE)
)
print("--- Resumo de Valores Mínimos (Devem ser >= 0) ---")
print(check_negativos)
# 4. Ver as primeiras linhas para conferência visual
print("--- Primeiras 5 linhas dos resultados ---")
print(head(res[, c("sample_id", "Fv_Fm", "Vj", "PI_abs", "phi_Eo")]))

# --- FORÇANDO A DEFINIÇÃO CORRETA NA MEMÓRIA ---
read_handypea_csv <- function(file) {
# Ler linhas para achar cabeçalho
lines <- readLines(file, warn = FALSE)
header_idx <- grep("Record No", lines)[1]
if (is.na(header_idx)) stop("ERRO: Não achei 'Record No' no arquivo.")
# Ler tabela ignorando o lixo inicial
# check.names=FALSE é vital para manter tempos numéricos
df <- utils::read.csv(file, skip = header_idx - 1, header = TRUE,
check.names = FALSE, stringsAsFactors = FALSE)
# Remover coluna vazia final (comum no HandyPEA) e linha EOF
df <- df[, !apply(df, 2, function(x) all(is.na(x) | x == ""))]
df <- df[!grepl("End Of File", df[[1]]), ]
# Matriz de dados
mat_data <- as.matrix(df[, -1, drop = FALSE])
mode(mat_data) <- "numeric"
# Extrair tempos do cabeçalho
times_s <- suppressWarnings(as.numeric(colnames(mat_data)))
# Filtrar apenas colunas que são tempos válidos
valid_cols <- !is.na(times_s)
mat_data <- mat_data[, valid_cols, drop = FALSE]
times_s <- times_s[valid_cols]
list(times_s = times_s, ids = as.character(df[[1]]), mat = mat_data)
}
# Teste final (Recrie o arquivo caso tenha apagado)
csv_content <- c(
"Record No,0.00005,0.0001,0.0003,0.002,0.03,0.1,0.3,1.0",
"Plant_Control_1,400,600,800,1200,1800,2400,2500,2500",
"Plant_Stress_1,420,650,900,1500,1600,1700,1750,1750",
"End Of File"
)
writeLines(csv_content, "teste_final.csv")
# AGORA VAI:
plot_normalized_fluorescence("teste_final.csv")
read_handypea_csv <- function(file) {
# 1. Ler o arquivo como texto bruto
lines <- readLines(file, warn = FALSE)
# 2. Achar a linha do cabeçalho
idx <- grep("Record No", lines)[1]
if (is.na(idx)) stop("Cabeçalho 'Record No' não encontrado.")
# 3. EXTRAIR TEMPOS MANUALMENTE (Blindado contra erros de coluna)
# Removemos aspas e dividimos por vírgula
header_clean <- gsub('"', '', lines[idx])
parts <- strsplit(header_clean, ",")[[1]]
# Tentamos converter tudo para número. "Record No" vai virar NA.
times_vals <- suppressWarnings(as.numeric(parts))
# Pegamos apenas o que é número válido (os tempos)
valid_indices <- !is.na(times_vals)
times_s <- times_vals[valid_indices]
if (length(times_s) == 0) stop("Não foi possível ler os tempos do cabeçalho.")
# 4. Ler os dados (Corpo da tabela)
# skip = idx (pula o cabeçalho pois já lemos)
# header = FALSE (não queremos que o R tente adivinhar nomes)
df <- utils::read.csv(file, skip = idx, header = FALSE, stringsAsFactors = FALSE)
# Limpeza básica (remover linhas/colunas vazias)
df <- df[!grepl("End Of File", df[[1]]), ]
df <- df[, !apply(df, 2, function(x) all(is.na(x) | x == ""))]
# 5. Montar a Matriz
# A coluna 1 é ID. As colunas 2 em diante são dados.
ids <- as.character(df[[1]])
mat_data <- as.matrix(df[, -1, drop = FALSE])
# Garantir que o número de colunas bate com o número de tempos lidos
# Se sobrar colunas extras (lixo), cortamos.
if (ncol(mat_data) > length(times_s)) {
mat_data <- mat_data[, 1:length(times_s), drop = FALSE]
}
# Forçar numérico e nomear
mode(mat_data) <- "numeric"
colnames(mat_data) <- times_s
rownames(mat_data) <- ids
list(times_s = times_s, ids = ids, mat = mat_data)
}
read_handypea_csv <- function(file) {
# 1. Ler o arquivo como texto bruto
lines <- readLines(file, warn = FALSE)
# 2. Achar a linha do cabeçalho
idx <- grep("Record No", lines)[1]
if (is.na(idx)) stop("Cabeçalho 'Record No' não encontrado.")
# 3. EXTRAIR TEMPOS MANUALMENTE (Blindado contra erros de coluna)
# Removemos aspas e dividimos por vírgula
header_clean <- gsub('"', '', lines[idx])
parts <- strsplit(header_clean, ",")[[1]]
# Tentamos converter tudo para número. "Record No" vai virar NA.
times_vals <- suppressWarnings(as.numeric(parts))
# Pegamos apenas o que é número válido (os tempos)
valid_indices <- !is.na(times_vals)
times_s <- times_vals[valid_indices]
if (length(times_s) == 0) stop("Não foi possível ler os tempos do cabeçalho.")
# 4. Ler os dados (Corpo da tabela)
# skip = idx (pula o cabeçalho pois já lemos)
# header = FALSE (não queremos que o R tente adivinhar nomes)
df <- utils::read.csv(file, skip = idx, header = FALSE, stringsAsFactors = FALSE)
# Limpeza básica (remover linhas/colunas vazias)
df <- df[!grepl("End Of File", df[[1]]), ]
df <- df[, !apply(df, 2, function(x) all(is.na(x) | x == ""))]
# 5. Montar a Matriz
# A coluna 1 é ID. As colunas 2 em diante são dados.
ids <- as.character(df[[1]])
mat_data <- as.matrix(df[, -1, drop = FALSE])
# Garantir que o número de colunas bate com o número de tempos lidos
# Se sobrar colunas extras (lixo), cortamos.
if (ncol(mat_data) > length(times_s)) {
mat_data <- mat_data[, 1:length(times_s), drop = FALSE]
}
# Forçar numérico e nomear
mode(mat_data) <- "numeric"
colnames(mat_data) <- times_s
rownames(mat_data) <- ids
list(times_s = times_s, ids = ids, mat = mat_data)
}
# Caso precise recriar o arquivo:
csv_content <- c(
"Record No,0.00005,0.0001,0.0003,0.002,0.03,0.1,0.3,1.0",
"Plant_Control_1,400,600,800,1200,1800,2400,2500,2500",
"Plant_Stress_1,420,650,900,1500,1600,1700,1750,1750",
"End Of File"
)
writeLines(csv_content, "teste_final.csv")
# O MOMENTO DA VERDADE:
